*{
box-sizing:border-box;
font-family:Arial, sans-serif;
}

body{
margin:0;
background:#000;
color:white;
}


header{
display:flex;
justify-content:space-between;
align-items:center;
padding:25px;
border-bottom:1px solid #333;
}


.logo{
font-size:30px;
font-weight:bold;
letter-spacing:3px;
}


.logo span{
background:white;
color:black;
padding:5px;
}


.logo b{
color:white;
}


nav a{
color:white;
text-decoration:none;
margin-left:15px;
}


.hero{
height:80vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
}


.hero h1{
font-size:70px;
letter-spacing:8px;
}


.hero p{
font-size:20px;
}


button{
background:white;
color:black;
border:none;
padding:15px 30px;
font-weight:bold;
cursor:pointer;
}


section{
padding:50px 20px;
}


h2{
text-align:center;
font-size:40px;
}


.products{
display:flex;
justify-content:center;
gap:30px;
flex-wrap:wrap;
}


.product{
background:#111;
padding:25px;
width:300px;
text-align:center;
border:1px solid #222;
}


.image{
height:250px;
background:#050505;
display:flex;
align-items:center;
justify-content:center;
font-size:35px;
font-weight:bold;
letter-spacing:3px;
}


select{
width:100%;
padding:10px;
margin:15px 0;
background:#000;
color:white;
border:1px solid #444;
}


.add{
width:100%;
}


#cart{
background:#080808;
}


input, textarea{

display:block;
width:90%;
max-width:500px;
margin:15px auto;
padding:15px;
background:#111;
border:1px solid #444;
color:white;

}


textarea{
height:150px;
}


#contact button{
display:block;
margin:auto;
}


footer{
text-align:center;
padding:30px;
border-top:1px solid #333;
}



@media(max-width:700px){

header{
flex-direction:column;
gap:20px;
}


.hero h1{
font-size:45px;
}


.products{
flex-direction:column;
align-items:center;
}

}